{
  "name": "afonsodev-web",
  "dockerComposeFile": "compose.yml",
  "service": "app",
  "workspaceFolder": "/afonsodev-web",

  "mounts": [
    // cli
    "source=${localEnv:HOME}/.fns-cli,target=/home/vscode/.fns-cli,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.bash_history,target=/home/vscode/.bash_history,type=bind,consistency=cached",
    // devtools
    "source=${localEnv:HOME}/.cloudflared,target=/home/vscode/.cloudflared,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    // source code
    "source=${localWorkspaceFolder},target=/afonsodev-web,type=bind,consistency=cached"
  ],

  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": { "moby": false },
    "ghcr.io/devcontainers-extra/features/cloudflared:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "Vue.volar",
        "EditorConfig.EditorConfig",
        "esbenp.prettier-vscode",
        "mkhl.shfmt",
        "eamodio.gitlens",
        "Anthropic.claude-code"
      ]
    }
  },

  "postCreateCommand": "bash .devcontainer/install.sh"
}
